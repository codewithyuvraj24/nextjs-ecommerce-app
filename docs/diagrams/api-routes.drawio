        <mxCell id="c-rev" value="&lt;b&gt;reviewController&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcedc8;strokeColor=#689f38;fontSize=10;align=center;arcSize=8;" vertex="1" parent="1">
