        <mxCell id="r-orders" value="&lt;b&gt;/api/orders&lt;/b&gt;&lt;hr size='1'&gt;&lt;span style='color:#2e7d32'&gt;POST&lt;/span&gt; / &lt;i style='font-size:10px'&gt;create order&lt;/i&gt;&lt;br&gt;&lt;span style='color:#1565c0'&gt;GET&lt;/span&gt; /myorders &lt;i style='font-size:10px'&gt;user's orders&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1976d2;fontSize=11;align=left;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="620" y="470" width="230" height="65" as="geometry" />
        </mxCell>

        <mxCell id="r-payment" value="&lt;b&gt;/api/payment&lt;/b&gt;&lt;hr size='1'&gt;&lt;span style='color:#2e7d32'&gt;POST&lt;/span&gt; /create-order &lt;i style='font-size:10px'&gt;Razorpay init&lt;/i&gt;&lt;br&gt;&lt;span style='color:#2e7d32'&gt;POST&lt;/span&gt; /verify &lt;i style='font-size:10px'&gt;confirm signature&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1976d2;fontSize=11;align=left;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="870" y="470" width="235" height="65" as="geometry" />
