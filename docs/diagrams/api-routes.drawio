        </mxCell>
        <mxCell id="err-title" value="&lt;b&gt;Error Middleware&lt;/b&gt;&lt;hr size='1'&gt;Catches all unhandled errors&lt;br&gt;&lt;i style='font-size:10px'&gt;Registered LAST after all routes&lt;/i&gt;" style="text;html=1;fontSize=11;fontColor=#b71c1c;align=center;" vertex="1" parent="1">
