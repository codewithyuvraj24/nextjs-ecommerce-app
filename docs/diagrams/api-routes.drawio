        <!-- Admin controllers -->
        <mxCell id="c-prod-adm" value="&lt;b&gt;productController&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=10;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="250" y="905" width="140" height="25" as="geometry" />
        </mxCell>
        <mxCell id="c-ord-adm" value="&lt;b&gt;orderController&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=10;align=center;arcSize=8;" vertex="1" parent="1">
