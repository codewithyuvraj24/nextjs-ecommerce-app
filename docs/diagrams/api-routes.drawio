  <diagram id="api-flow-v3" name="API Request Lifecycle">
    <mxGraphModel dx="1800" dy="1500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ══════════════════════════════════════════════ -->
        <!-- TITLE                                         -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="title" value="&lt;b style='font-size:22px;color:#0d1b2a'&gt;Backend — API Request Lifecycle &amp;amp; Routes&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:12px;color:#666'&gt;Express.js 5 · Node.js · PostgreSQL · Razorpay · Shiprocket&lt;/span&gt;" style="text;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="440" y="10" width="560" height="50" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════════ -->
        <!-- INCOMING REQUEST                              -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="req" value="&lt;b&gt;Incoming HTTP Request&lt;/b&gt;" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;size=15;fillColor=#0d1b2a;fontColor=#ffffff;fontSize=14;align=center;strokeColor=#0d1b2a;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="560" y="75" width="320" height="45" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════════ -->
        <!-- GLOBAL MIDDLEWARE (applied to ALL requests)   -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="gmw-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede7f6;strokeColor=#7e57c2;strokeWidth=2;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="370" y="150" width="700" height="100" as="geometry" />
        </mxCell>
        <mxCell id="gmw-title" value="&lt;b&gt;Global Middleware&lt;/b&gt; &lt;i style='font-size:10px;color:#666'&gt;(applied to every /api request, in order)&lt;/i&gt;" style="text;html=1;fontSize=13;fontColor=#4527a0;align=center;" vertex="1" parent="1">
          <mxGeometry x="500" y="153" width="440" height="20" as="geometry" />
        </mxCell>

        <mxCell id="gm1" value="&lt;b&gt;1. Helmet&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;Security headers&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1c4e9;strokeColor=#7e57c2;fontSize=11;align=center;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="390" y="180" width="140" height="48" as="geometry" />
        </mxCell>
        <mxCell id="gm2" value="&lt;b&gt;2. Rate Limiter&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;100 req / 15 min / IP&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1c4e9;strokeColor=#7e57c2;fontSize=11;align=center;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="548" y="180" width="155" height="48" as="geometry" />
        </mxCell>
        <mxCell id="gm3" value="&lt;b&gt;3. CORS&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;Origin whitelist&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1c4e9;strokeColor=#7e57c2;fontSize=11;align=center;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="180" width="120" height="48" as="geometry" />
        </mxCell>
        <mxCell id="gm4" value="&lt;b&gt;4. JSON Parser&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;express.json()&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1c4e9;strokeColor=#7e57c2;fontSize=11;align=center;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="858" y="180" width="140" height="48" as="geometry" />
        </mxCell>

        <!-- Global middleware arrows (left to right) -->
        <mxCell id="g12" style="html=1;strokeColor=#7e57c2;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="gm1" target="gm2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="g23" style="html=1;strokeColor=#7e57c2;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="gm2" target="gm3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="g34" style="html=1;strokeColor=#7e57c2;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="gm3" target="gm4"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Request → Global MW -->
        <mxCell id="a-req-gmw" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0d1b2a;strokeWidth=2;" edge="1" parent="1" source="req" target="gmw-bg"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ══════════════════════════════════════════════ -->
        <!-- ROUTE BRANCH POINT                            -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="branch" value="&lt;b&gt;Route&lt;br&gt;Dispatcher&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3f51b5;fontSize=12;align=center;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="640" y="280" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="a-gmw-branch" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#3f51b5;strokeWidth=2;" edge="1" parent="1" source="gmw-bg" target="branch"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ══════════════════════════════════════════════ -->
        <!-- BRANCH A: PUBLIC ROUTES (left column)         -->
        <!-- No JWT middleware — requests go straight in   -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="pub-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;strokeWidth=2;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="400" width="520" height="280" as="geometry" />
        </mxCell>
        <mxCell id="pub-title" value="&lt;b style='font-size:14px'&gt;PUBLIC ROUTES&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#555'&gt;No auth middleware — open access&lt;/span&gt;" style="text;html=1;fontColor=#1b5e20;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="405" width="300" height="35" as="geometry" />
        </mxCell>

        <mxCell id="r-auth" value="&lt;b&gt;/api/auth&lt;/b&gt;&lt;hr size='1'&gt;&lt;span style='color:#2e7d32'&gt;POST&lt;/span&gt; /register&lt;br&gt;&lt;span style='color:#2e7d32'&gt;POST&lt;/span&gt; /login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#43a047;fontSize=11;align=left;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="455" width="220" height="70" as="geometry" />
        </mxCell>

        <mxCell id="r-prod-pub" value="&lt;b&gt;/api/products&lt;/b&gt; &lt;span style='font-size:9px;color:#888'&gt;(public read)&lt;/span&gt;&lt;hr size='1'&gt;&lt;span style='color:#1565c0'&gt;GET&lt;/span&gt; / &lt;i style='font-size:10px'&gt;list + search + filter&lt;/i&gt;&lt;br&gt;&lt;span style='color:#1565c0'&gt;GET&lt;/span&gt; /:slug &lt;i style='font-size:10px'&gt;single product&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#43a047;fontSize=11;align=left;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="300" y="455" width="240" height="70" as="geometry" />
        </mxCell>

        <!-- REVIEWS — merged into ONE box with note -->
        <mxCell id="r-reviews" value="&lt;b&gt;/api/reviews&lt;/b&gt;&lt;hr size='1'&gt;[public] &lt;span style='color:#1565c0'&gt;GET&lt;/span&gt; /:productId &lt;i style='font-size:10px'&gt;— public read&lt;/i&gt;&lt;br&gt;[auth] &lt;span style='color:#2e7d32'&gt;POST&lt;/span&gt; /:productId &lt;i style='font-size:10px'&gt;— JWT required&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#43a047;fontSize=11;align=left;spacingLeft=10;arcSize=6;strokeWidth=1;strokeColor=#7cb342;dashed=1;" vertex="1" parent="1">
