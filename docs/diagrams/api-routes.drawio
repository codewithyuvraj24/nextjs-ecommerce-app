        <mxCell id="db" value="&lt;b&gt;PostgreSQL&lt;/b&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#fff9c4;strokeColor=#f9a825;strokeWidth=2;fontSize=13;fontColor=#e65100;" vertex="1" parent="1">
          <mxGeometry x="525" y="1060" width="150" height="65" as="geometry" />
