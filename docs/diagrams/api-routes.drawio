        <mxCell id="a-mod-db" value="SQL queries (pg)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#f9a825;strokeWidth=2;fontSize=10;fontColor=#f57f17;" edge="1" parent="1" source="models-bg" target="db"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ══════════════════════════════════════════════ -->
