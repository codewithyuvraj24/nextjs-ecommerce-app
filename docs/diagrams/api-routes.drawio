          <mxGeometry x="1330" y="478" width="105" height="42" as="geometry" />
        </mxCell>

        <!-- paymentController ─ ─ → Razorpay -->
        <mxCell id="ext-pay" value="payment API" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#ad1457;strokeWidth=2;dashed=1;fontSize=9;fontColor=#880e4f;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="r-payment" target="razorpay">
