        </mxCell>
        <mxCell id="rev-note" value="&lt;i style='font-size:9px;color:#666'&gt;Mixed access: read is public,&lt;br&gt;write goes through authMiddleware&lt;/i&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="350" y="565" width="190" height="30" as="geometry" />
        </mxCell>

        <!-- Public controllers -->
        <mxCell id="c-auth" value="&lt;b&gt;authController&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=10;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="90" y="640" width="130" height="25" as="geometry" />
        </mxCell>
        <mxCell id="c-prod-pub" value="&lt;b&gt;productController&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=10;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="340" y="640" width="140" height="25" as="geometry" />
        </mxCell>

        <mxCell id="ea1" style="rounded=1;html=1;strokeColor=#2e7d32;strokeWidth=1;" edge="1" parent="1" source="r-auth" target="c-auth"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea2" style="rounded=1;html=1;strokeColor=#2e7d32;strokeWidth=1;" edge="1" parent="1" source="r-prod-pub" target="c-prod-pub"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Branch → Public -->
        <mxCell id="a-br-pub" value="&lt;b&gt;public&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2e7d32;strokeWidth=2;fontSize=11;fontColor=#2e7d32;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="branch" target="pub-bg">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="300" y="315" /><mxPoint x="300" y="400" /></Array>
          </mxGeometry>
        </mxCell>

        <!-- ══════════════════════════════════════════════ -->
        <!-- BRANCH B: PROTECTED ROUTES (middle column)    -->
        <!-- JWT authMiddleware applied PER ROUTE          -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="prot-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;strokeWidth=2;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="400" width="520" height="280" as="geometry" />
        </mxCell>
        <mxCell id="prot-title" value="&lt;b style='font-size:14px'&gt;PROTECTED ROUTES&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#555'&gt;authMiddleware(JWT) applied per route&lt;/span&gt;" style="text;html=1;fontColor=#0d47a1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="610" y="405" width="320" height="35" as="geometry" />
        </mxCell>

        <!-- Auth middleware badge inside protected box -->
        <mxCell id="jwt-badge" value="&lt;b&gt;5. authMiddleware&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:9px'&gt;JWT verify · Bearer token&lt;br&gt;Sets req.user from decoded token&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c5cae9;strokeColor=#3949ab;fontSize=10;align=center;arcSize=8;strokeWidth=2;" vertex="1" parent="1">
