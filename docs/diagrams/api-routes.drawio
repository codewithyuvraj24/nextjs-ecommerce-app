        <mxCell id="models-label" value="&lt;b&gt;Models:&lt;/b&gt; userModel · productModel · orderModel · reviewModel · wishlistModel" style="text;html=1;fontSize=12;fontColor=#f57f17;align=center;" vertex="1" parent="1">
