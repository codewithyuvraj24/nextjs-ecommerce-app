        <mxCell id="ep1" style="rounded=1;html=1;strokeColor=#1565c0;strokeWidth=1;" edge="1" parent="1" source="r-orders" target="c-order"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ep2" style="rounded=1;html=1;strokeColor=#1565c0;strokeWidth=1;" edge="1" parent="1" source="r-payment" target="c-pay"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ep-rev" style="rounded=1;html=1;strokeColor=#689f38;strokeWidth=1;" edge="1" parent="1" source="r-reviews" target="c-rev"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Branch → Protected -->
        <mxCell id="a-br-prot" value="&lt;b&gt;auth (JWT)&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#1565c0;strokeWidth=2;fontSize=11;fontColor=#1565c0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="branch" target="prot-bg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════════ -->
        <!-- BRANCH C: ADMIN ROUTES (bottom, full width)   -->
        <!-- JWT authMiddleware + adminMiddleware           -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="adm-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;strokeWidth=2;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="200" y="730" width="800" height="230" as="geometry" />
        </mxCell>
        <mxCell id="adm-title" value="&lt;b style='font-size:14px'&gt;ADMIN ROUTES&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#555'&gt;authMiddleware(JWT) + adminMiddleware (role === 'admin')&lt;/span&gt;" style="text;html=1;fontColor=#bf360c;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="210" y="735" width="450" height="35" as="geometry" />
        </mxCell>

        <!-- Admin role badge -->
        <mxCell id="admin-badge" value="&lt;b&gt;6. adminMiddleware&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:9px'&gt;Checks req.user.role === 'admin'&lt;br&gt;Returns 403 if not admin&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=10;align=center;arcSize=8;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="790" y="738" width="195" height="48" as="geometry" />
        </mxCell>

        <mxCell id="r-prod-adm" value="&lt;b&gt;/api/products&lt;/b&gt; &lt;span style='font-size:9px;color:#888'&gt;(admin write)&lt;/span&gt;&lt;hr size='1'&gt;&lt;span style='color:#2e7d32'&gt;POST&lt;/span&gt; / &lt;i style='font-size:10px'&gt;create product&lt;/i&gt;&lt;br&gt;&lt;span style='color:#ff6f00'&gt;PUT&lt;/span&gt; /:id &lt;i style='font-size:10px'&gt;update product&lt;/i&gt;&lt;br&gt;&lt;span style='color:#c62828'&gt;DELETE&lt;/span&gt; /:id &lt;i style='font-size:10px'&gt;remove product&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ef6c00;fontSize=11;align=left;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="220" y="800" width="230" height="85" as="geometry" />
        </mxCell>

        <mxCell id="r-ord-adm" value="&lt;b&gt;/api/orders&lt;/b&gt; &lt;span style='font-size:9px;color:#888'&gt;(admin)&lt;/span&gt;&lt;hr size='1'&gt;&lt;span style='color:#1565c0'&gt;GET&lt;/span&gt; / &lt;i style='font-size:10px'&gt;all orders&lt;/i&gt;&lt;br&gt;&lt;span style='color:#ff6f00'&gt;PUT&lt;/span&gt; /:id/status &lt;i style='font-size:10px'&gt;update status&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ef6c00;fontSize=11;align=left;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="480" y="800" width="230" height="75" as="geometry" />
        </mxCell>

        <mxCell id="r-logistics" value="&lt;b&gt;/api/logistics&lt;/b&gt;&lt;hr size='1'&gt;&lt;span style='color:#2e7d32'&gt;POST&lt;/span&gt; /ship &lt;i style='font-size:10px'&gt;create shipment&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ef6c00;fontSize=11;align=left;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="740" y="805" width="230" height="55" as="geometry" />
