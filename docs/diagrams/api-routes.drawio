        <mxCell id="c-logistics" value="&lt;b&gt;logisticsController&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=10;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="775" y="880" width="145" height="25" as="geometry" />
        </mxCell>

        <mxCell id="ea-p" style="rounded=1;html=1;strokeColor=#e65100;strokeWidth=1;" edge="1" parent="1" source="r-prod-adm" target="c-prod-adm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea-o" style="rounded=1;html=1;strokeColor=#e65100;strokeWidth=1;" edge="1" parent="1" source="r-ord-adm" target="c-ord-adm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea-l" style="rounded=1;html=1;strokeColor=#e65100;strokeWidth=1;" edge="1" parent="1" source="r-logistics" target="c-logistics"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Button from protected → admin (admin is a superset of protected) -->
        <mxCell id="a-prot-adm" value="&lt;b&gt;admin only&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#e65100;strokeWidth=2;fontSize=10;fontColor=#e65100;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="prot-bg" target="adm-bg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════════ -->
        <!-- DATA LAYER: Models → PostgreSQL               -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="models-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;strokeWidth=2;arcSize=6;" vertex="1" parent="1">
