        <mxCell id="razorpay" value="&lt;b&gt;Razorpay&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;Payment Gateway&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ad1457;fontSize=11;align=center;arcSize=6;" vertex="1" parent="1">
