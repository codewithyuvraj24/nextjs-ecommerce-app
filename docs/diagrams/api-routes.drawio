        <mxCell id="legend-text" value="&lt;b style='font-size:12px'&gt;Legend&lt;/b&gt;&lt;hr size='1'&gt;&lt;b&gt;Access Levels:&lt;/b&gt;&lt;br&gt;&lt;span style='color:#2e7d32'&gt;[PUBLIC]&lt;/span&gt; — no auth needed&lt;br&gt;&lt;span style='color:#1565c0'&gt;[PROTECTED]&lt;/span&gt; — JWT per route&lt;br&gt;&lt;span style='color:#e65100'&gt;[ADMIN]&lt;/span&gt; — JWT + role check&lt;br&gt;&lt;br&gt;&lt;b&gt;HTTP Methods:&lt;/b&gt;&lt;br&gt;&lt;span style='color:#1565c0'&gt;GET&lt;/span&gt; · &lt;span style='color:#2e7d32'&gt;POST&lt;/span&gt; · &lt;span style='color:#ff6f00'&gt;PUT&lt;/span&gt; · &lt;span style='color:#c62828'&gt;DELETE&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Lines:&lt;/b&gt; solid = data flow, dashed = external" style="text;html=1;fontSize=11;fontColor=#333;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1208" y="703" width="245" height="162" as="geometry" />
        </mxCell>

